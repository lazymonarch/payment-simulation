# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=payments
POSTGRES_USER=payuser
POSTGRES_PASSWORD=paypass
DATABASE_URL=postgresql://payuser:paypass@postgres:5432/payments

# Redis
REDIS_URL=redis://redis:6379/0
IDEMPOTENCY_TTL_SECONDS=86400

# Queue
QUEUE_BACKEND=redis
QUEUE_STREAM_NAME=payment.requested
DLQ_STREAM_NAME=payment.dlq
CONSUMER_GROUP=payment-processors
NUM_WORKERS=4

# Retry
MAX_RETRIES=3
BASE_RETRY_DELAY_SECONDS=1

# Rate limiting
DEFAULT_RATE_LIMIT_PER_SEC=100

# Kafka (only if QUEUE_BACKEND=kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
